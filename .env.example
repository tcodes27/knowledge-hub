# Google Apps Script Web App deployment URL (required)
# Copy this file to .env.local and set your deployed endpoint here.
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxpmOIPCyU1GwLdVdBx9fAWcDTS_dQbuO2zLnBfYaxp55bmOc_QA6rOt1WrAH9SOZZUrQ/exec

# Google Spreadsheet ID used by Apps Script (optional)
VITE_GOOGLE_SHEET_ID=

# Google Drive folder used for generated documentation (optional)
VITE_GOOGLE_DRIVE_FOLDER_ID=